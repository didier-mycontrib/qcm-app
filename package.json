{
  "name": "qcm-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --base-href .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "ic": "start-server-and-test 'http-server --port 3000 --proxy https://www.d-defrance.fr -c-1 dist/qcm-app/browser' 3000 'npx cypress run --spec ./cypress/e2e/*.spec.cy.js --reporter json --reporter-options output=test-report.json'",
    "serve:ssr:qcm-app": "node dist/qcm-app/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "~21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.0",
    "angular-oauth2-oidc": "^20.0.2",
    "d2f-ngx-components": "^0.0.6",
    "d2f-ngx-crud": "^0.0.4",
    "d2f-ngx-forms": "^0.0.5",
    "d2f-ngx-layout": "^0.0.4",
    "d2f-ngx-session": "^0.0.4",
    "d2f-ngx-util": "^0.0.4",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.9.2",
    "vitest": "^4.1.0"
  }
}
